# Stage 1: Build frontend
FROM node:20-slim AS frontend
WORKDIR /app/web
COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ ./
RUN npm run build

# Stage 2: Lightweight Python runtime (no PyTorch/FFmpeg/Demucs)
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml ./
COPY src/ ./src/
RUN pip install --no-cache-dir -e ".[web,openai,terms]"

# Copy frontend build output + package.json (sentinel for cli.py static discovery)
COPY --from=frontend /app/web/dist ./web/dist
COPY web/package.json ./web/package.json

VOLUME /data
ENV APP_DATA_DIR=/data

EXPOSE 8765

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8765/api/health || exit 1

CMD ["vsd", "ide", "--no-worker", "--port", "8765"]
