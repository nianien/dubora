# Dubora Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# ── Core ──
# APP_DATA_DIR=/data          # Set by Docker, no need to change
DB_URL=postgresql://dubora:dubora@localhost:5432/dubora

# ── Doubao / VolcEngine (ASR + TTS) ──
DOUBAO_APPID=
DOUBAO_ACCESS_TOKEN=

# ── TOS Object Storage (ASR audio upload) ──
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
# TOS_REGION=cn-beijing          # default
# TOS_BUCKET=pikppo-video        # default

# ── OpenAI (translation) ──
OPENAI_API_KEY=

# ── Google Gemini (translation, alternative) ──
# GEMINI_API_KEY=

# ── Google Cloud Storage (media fallback) ──
# 默认走 Application Default Credentials (ADC)：
#   本地：gcloud auth application-default login
#   GCP 内部署：VM/容器绑 service account，metadata 自动鉴权
# 仅在特殊场景（如 CI 用 SA key 文件）需要显式指定 SA key：
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS_BUCKET=dubora              # default

# ── SiliconFlow (Fish Speech V1.5 / IndexTTS2) ──
# SILICONFLOW_API_KEY=

# ── fal.ai (IndexTTS2) ──
# FAL_KEY=

# ── Fish Audio (Fish Speech) ──
# FISH_API_KEY=

# ── TTS 引擎切换（volcengine / fish）──
# TTS_ENGINE=volcengine

# ── DashScope / Alibaba (Qwen ASR / Paraformer) ──
# DASHSCOPE_API_KEY=

# ── Azure Speech (optional TTS provider) ──
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=

# ── Auth (optional, disabled if GOOGLE_CLIENT_ID is empty) ──
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AUTH_SECRET_KEY=                          # cookie signing key
# AUTH_ALLOWED_EMAILS=a@gmail.com,b@gmail.com  # whitelist (empty = allow all)
